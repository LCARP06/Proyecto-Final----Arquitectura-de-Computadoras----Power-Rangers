`timescale 1ns / 1ps

module DPTR_tb;

    reg clk;
    reg reset;

    DPTR uut (
        .clk(clk),
        .reset(reset)
    );

    always begin
        #5 clk = ~clk;
    end

    initial begin
        clk = 0;
        reset = 1;

        $readmemh("bubble_decodificado", uut.instruction_memory.ram);
        $readmemh("TestF1_BReg", uut.mem.ram_datos);
       
        #20;
        reset = 0;

        #500000;

        $display("========================================");
        $display("RESULTADO FINAL DE MEMORIA");
        $display("========================================");

        $display("mem[0] = %d", uut.mem.ram_datos[0]);
        $display("mem[1] = %d", uut.mem.ram_datos[1]);
        $display("mem[2] = %d", uut.mem.ram_datos[2]);
        $display("mem[3] = %d", uut.mem.ram_datos[3]);
        $display("mem[4] = %d", uut.mem.ram_datos[4]);
        $display("mem[5] = %d", uut.mem.ram_datos[5]);
        $display("mem[6] = %d", uut.mem.ram_datos[6]);
        $display("mem[7] = %d", uut.mem.ram_datos[7]);
        $display("mem[8] = %d", uut.mem.ram_datos[8]);

        $display("========================================");

        $stop;
    end

endmodule